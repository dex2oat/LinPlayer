{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinPlayerPoC",
  "version": "0.1.0",
  "identifier": "com.linplayer.poc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LinPlayer PoC",
        "width": 1180,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["libmpv/libmpv-2.dll"]
  }
}
