# 本地调试用环境变量（复制为 .dev.vars，勿提交）。
# 线上请在 Cloudflare Pages 项目的 Settings → Environment variables 里配置同名变量。
TRAKT_CLIENT_ID=你的TraktClientId
TRAKT_CLIENT_SECRET=你的TraktClientSecret
BANGUMI_APP_ID=你的BangumiAppId
BANGUMI_APP_SECRET=你的BangumiAppSecret
# 可选：客户端与代理之间的共享密钥（与 App 的 kSyncProxyKey 保持一致）
LINPLAYER_PROXY_KEY=
# 爱发电赞助者名单（/afdian/sponsors.svg 用）。TOKEN 线上务必设为 Encrypted。
# 两者都在爱发电 dashboard/dev（开发者）页面获取。
AFDIAN_USER_ID=你的爱发电UserId
AFDIAN_TOKEN=你的爱发电Token
# 活跃用户徽章（/sentry/users 用）。只需 org:read 权限的 Sentry Auth Token，线上设为 Encrypted。
SENTRY_TOKEN=你的Sentry只读Token
