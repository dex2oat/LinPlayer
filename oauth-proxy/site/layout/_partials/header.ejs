<%
// Blingee Pixel header: no full-screen hero — just the navbar plus a compact,
// in-flow title plate. The page background is one continuous pixel scene, so
// content flows directly under the bar with no seam.
var intro = page.subtitle || page.title || config.subtitle || ''
var showIntro = !!intro
%>

<%- partial('_partials/header/navigation') %>

<% if (showIntro) { %>
  <div class="page-intro">
    <div class="page-intro__plate">
      <span class="page-intro__title"><%- intro %></span>
    </div>
  </div>
<% } %>
