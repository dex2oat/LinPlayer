{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* 各端共用层。必须与 vite.config.ts 的 resolve.alias 逐字一致 —— 只改一边的话
       vite 构建是绿的、`tsc` 直接红,而 npm run build 是 `tsc && vite build`。 */
    "baseUrl": ".",
    "paths": { "@shared/*": ["ui/shared/*"] },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["ui"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
